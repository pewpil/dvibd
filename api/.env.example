# Copy this file to `.env` and adjust as needed. `.env` is gitignored.

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# Port the HTTP server listens on
PORT=4000

# PostgreSQL connection string.
# Defaults below match db/docker-compose.yml.
DATABASE_URL=postgres://dvibd:dvibd_dev_password@localhost:5432/dvibd

# Allowed origin(s) for CORS (the gui dev server runs on :3000)
CORS_ORIGIN=http://localhost:3000
